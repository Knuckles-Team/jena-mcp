{
  "mcpServers": {
    "jena-mcp": {
      "command": "uv",
      "args": [
        "run",
        "jena-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "FASTMCP_LOG_LEVEL": "<YOUR_FASTMCP_LOG_LEVEL>",
        "NO_COLOR": "<YOUR_NO_COLOR>",
        "TERM": "<YOUR_TERM>",
        "AGENT_DESCRIPTION": "<YOUR_AGENT_DESCRIPTION>",
        "AGENT_SYSTEM_PROMPT": "<YOUR_AGENT_SYSTEM_PROMPT>",
        "DEFAULT_AGENT_NAME": "<YOUR_DEFAULT_AGENT_NAME>",
        "MCP_URL": "<YOUR_MCP_URL>",
        "JENA_FUSEKI_URL": "<YOUR_JENA_FUSEKI_URL>",
        "JENA_TOKEN": "<YOUR_JENA_TOKEN>",
        "JENA_USERNAME": "<YOUR_JENA_USERNAME>",
        "JENA_PASSWORD": "<YOUR_JENA_PASSWORD>",
        "JENA_SSL_VERIFY": "<YOUR_JENA_SSL_VERIFY>",
        "JENATOOL": "True"
      }
    }
  }
}
